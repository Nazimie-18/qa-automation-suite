# 环境配置示例文件 - 复制为 .env 并填入实际值

# 应用环境
ENVIRONMENT=dev

# 浏览器配置
BROWSER=chrome
HEADLESS=False

# API服务
PYTHON_API_URL=http://localhost:8000
NODEJS_API_URL=http://localhost:3000
JAVA_API_URL=http://localhost:8080

# 数据库
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=test_db

# Appium
APPIUM_HOST=localhost
APPIUM_PORT=4723

# 邮件
EMAIL_ENABLED=False
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your_email@gmail.com
SENDER_PASSWORD=your_password

# 日志
LOG_LEVEL=DEBUG

# 其他
TEST_TIMEOUT=30
IMPLICIT_WAIT=10
EXPLICIT_WAIT=15
